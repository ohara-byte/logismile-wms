// 大江ノ郷自然牧場 WMS — Prisma schema
// 詳細なテーブル定義は docs/DB設計書.md を参照
// 全27テーブル：マスタ16 + トランザクション9 + システム2

generator client {
  provider = "prisma-client-js"
  // 2026-06-06: 本番 VPS（Linux / node:20-bookworm-slim = Debian 12 / OpenSSL 3.x）用の
  //   クエリエンジンも生成する。これが無いと Linux コンテナ起動時に
  //   「Query engine library for current platform could not be found」で落ちる。
  //   native = 開発機(Windows)用、debian-openssl-3.0.x = 本番コンテナ用。
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// マスタ系（16テーブル）
// =====================================================

/// 1. 構成商品マスタ
model Product {
  code      String   @id @db.VarChar(20)
  jan       String?  @db.VarChar(13)
  name      String   @db.VarChar(100)
  cat       String   @db.VarChar(20)
  pkg       String   @default("箱") @db.VarChar(20)
  price     Int      @default(0)
  leadDays  Int      @default(0) @map("lead_days")
  stdSec    Int      @default(0) @map("std_sec")
  frozen    Boolean  @default(false)
  special   Boolean  @default(false)
  noshi     Boolean  @default(false)
  active    Boolean  @default(true)
  note      String?  @db.Text
  /// Sprint Z-1: 商品種別（'pass_through' = 通過型 / 'warehouse' = 倉庫在庫 / 'made_to_order' = 受注生産）
  /// Sprint Y-13: 大江ノ郷の基本運用が通過型のため既定を pass_through に変更
  productType  String   @default("pass_through") @map("product_type") @db.VarChar(20)
  /// 安全在庫（reorderPoint と組み合わせて補充タイミング判定）
  safetyStock  Int      @default(0) @map("safety_stock")
  reorderPoint Int?     @map("reorder_point")
  /// 発送可能賞味期限（日数）。工場(/delivery)からの shippableExpiryDays を保存。
  /// 在庫検品の完了後バナーで「入庫日 + 日数 - 1」の発送可能日を算出（A・2026-06-12）。
  shippableExpiryDays Int? @map("shippable_expiry_days")
  /// カタログ商品番号（例 700-01）。構成商品サイズ一覧との突合キー（JAN軸ファイルで紐付け・2026-06-22）
  catalogNo String? @map("catalog_no") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  auxAttr            ProductAuxAttr?
  shippingOrderItems ShippingOrderItem[]
  stock              Stock?
  manufacturingInstructions ManufacturingInstruction[]

  @@index([jan])
  @@index([cat])
  @@index([productType])
  @@index([catalogNo])
  @@map("products")
}

/// 1-A. 在庫マスタ（Sprint Z-1） — SKU 単位の在庫サマリ（1 商品 1 行）
model Stock {
  productCode  String    @id @map("product_code") @db.VarChar(20)
  qty          Int       @default(0)
  allocatedQty Int       @default(0) @map("allocated_qty")
  inspectedAt  DateTime? @map("inspected_at") @db.Timestamptz
  inspectedBy  String?   @map("inspected_by") @db.VarChar(10)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  product     Product         @relation(fields: [productCode], references: [code], onDelete: Cascade)
  movements   StockMovement[]
  allocations Allocation[]

  @@map("stocks")
}

/// 1-B. 在庫増減ログ（Sprint Z-1）
///   type: 'inbound' / 'outbound' / 'adjust' / 'inspection_count' / 'production_complete'
model StockMovement {
  id          Int      @id @default(autoincrement())
  productCode String   @map("product_code") @db.VarChar(20)
  type        String   @db.VarChar(20)
  qtyDelta    Int      @map("qty_delta")
  /// 関連エンティティ種別（'order' / 'instruction' / 'session' / null）
  refType     String?  @map("ref_type") @db.VarChar(20)
  refId       String?  @map("ref_id") @db.VarChar(40)
  note        String?  @db.Text
  createdBy   String?  @map("created_by") @db.VarChar(10)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  stock Stock @relation(fields: [productCode], references: [productCode], onDelete: Cascade)

  @@index([productCode, createdAt])
  @@index([refType, refId])
  @@map("stock_movements")
}

/// 1-C. 引当行（Sprint Z-1） — 出荷指示×商品ごとの引当数
///   status: 'reserved'（引当済・未出荷）/ 'fulfilled'（出荷完了）/ 'released'（取消）
///   source: 'warehouse' / 'pass_through' / 'made_to_order'
model Allocation {
  id           Int      @id @default(autoincrement())
  orderId      String   @map("order_id") @db.Uuid
  pkNo         String   @map("pk_no") @db.VarChar(30)
  productCode  String   @map("product_code") @db.VarChar(20)
  qty          Int
  status       String   @default("reserved") @db.VarChar(20)
  source       String   @default("warehouse") @db.VarChar(20)
  allocatedAt  DateTime @default(now()) @map("allocated_at") @db.Timestamptz
  fulfilledAt  DateTime? @map("fulfilled_at") @db.Timestamptz
  sessionId    String?  @map("session_id") @db.Uuid

  order ShippingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stock Stock         @relation(fields: [productCode], references: [productCode])

  @@unique([orderId, productCode])
  @@index([productCode, status])
  @@index([pkNo])
  @@map("allocations")
}

/// 1-D. 製造指示（Sprint Z-1）
///   status: 'draft'（自動下書き）/ 'pending'（送信待ち）/ 'sent'（工場送信済）/
///           'producing'（生産中）/ 'completed'（完成）/ 'cancelled'（取消）
model ManufacturingInstruction {
  id            Int      @id @default(autoincrement())
  instructionNo String   @unique @map("instruction_no") @db.VarChar(30)
  productCode   String   @map("product_code") @db.VarChar(20)
  qty           Int
  shortageQty   Int      @default(0) @map("shortage_qty")
  status        String   @default("draft") @db.VarChar(20)
  /// Sprint Z-4: 承認フラグ。true で「更新」ボタン押下時に一括で工場送信
  approved      Boolean  @default(false) @map("approved")
  targetDate    DateTime @map("target_date") @db.Date
  requestedBy   String?  @map("requested_by") @db.VarChar(10)
  factoryRef    String?  @map("factory_ref") @db.VarChar(60)
  sentAt        DateTime? @map("sent_at") @db.Timestamptz
  completedAt   DateTime? @map("completed_at") @db.Timestamptz
  note          String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  product Product @relation(fields: [productCode], references: [code])

  @@index([status, targetDate])
  @@index([productCode, status])
  @@index([approved, status])
  @@map("manufacturing_instructions")
}

/// 1-E. 在庫検品＋引当 セッション（Sprint Z-1）
///   既存 InspSession（出荷検品）とは独立した別系統
///   scope: 'inventory_count'（在庫検品）/ 'allocation_run'（引当ラン）/ 'production_input'（出来高入力）
model StockAllocSession {
  id          String    @id @default(uuid()) @db.Uuid
  staffCode   String    @map("staff_code") @db.VarChar(10)
  deviceCode  String    @map("device_code") @db.VarChar(20)
  scope       String    @db.VarChar(30)
  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  itemCount   Int       @default(0) @map("item_count")
  note        String?   @db.Text

  @@index([staffCode, startedAt])
  @@map("stock_alloc_sessions")
}

/// 2. 商品属性補助マスタ
model ProductAuxAttr {
  id          Int     @id @default(autoincrement())
  productCode String  @unique @map("product_code") @db.VarChar(20)
  dispName    String? @map("disp_name") @db.VarChar(100)
  tempZone    String  @default("ambient") @map("temp_zone") @db.VarChar(10)
  specialPkg  String? @map("special_pkg") @db.VarChar(30)
  stdSec      Int     @default(0) @map("std_sec")
  transferred Boolean @default(false)
  wMm         Int     @default(0) @map("w_mm")
  dMm         Int     @default(0) @map("d_mm")
  hMm         Int     @default(0) @map("h_mm")
  note        String? @db.Text

  product Product @relation(fields: [productCode], references: [code], onDelete: Cascade)

  @@map("product_aux_attrs")
}

/// 3. 構成品/同梱物マスタ
model SetComp {
  id           String   @id @db.VarChar(30)
  parentCode   String   @map("parent_code") @db.VarChar(20)
  parentName   String   @map("parent_name") @db.VarChar(100)
  type         String   @db.VarChar(20)
  fixedBoxCode String?  @map("fixed_box_code") @db.VarChar(30)
  packingNote  String?  @map("packing_note") @db.Text
  /// セット梱包標準時間（秒）。ダッシュボード終了予測(ETA)の主ドライバ。null=フォールバック（2026-06-22）
  stdSec       Int?     @map("std_sec")
  /// セット種別：bokujo（牧場セット）/ hanpukai（頒布会）/ other
  setKind      String?  @map("set_kind") @db.VarChar(20)
  /// stdSec の出所：imported（取込）/ manual（UI手入力）。再取込で手動値を保護
  stdSecSource String?  @map("std_sec_source") @db.VarChar(10)
  note         String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  fixedBox Box?           @relation(fields: [fixedBoxCode], references: [code])
  children SetCompChild[]

  @@index([parentCode])
  @@map("set_comps")
}

/// 4. 構成品明細
model SetCompChild {
  id        Int     @id @default(autoincrement())
  setCompId String  @map("set_comp_id") @db.VarChar(30)
  childCode String  @map("child_code") @db.VarChar(20)
  childName String? @map("child_name") @db.VarChar(100)
  qty       Int     @default(1)
  sortOrder Int     @default(0) @map("sort_order")

  setComp SetComp @relation(fields: [setCompId], references: [id], onDelete: Cascade)

  @@map("set_comp_children")
}

/// 5. 箱マスタ
model Box {
  code           String   @id @db.VarChar(30)
  name           String   @db.VarChar(100)
  type           String   @db.VarChar(20)
  sizeRank       Int      @map("size_rank")
  wMm            Int      @default(0) @map("w_mm")
  dMm            Int      @default(0) @map("d_mm")
  hMm            Int      @default(0) @map("h_mm")
  innerWMm       Int      @default(0) @map("inner_w_mm")
  innerDMm       Int      @default(0) @map("inner_d_mm")
  innerHMm       Int      @default(0) @map("inner_h_mm")
  frozen         Boolean  @default(false)
  noshi          Boolean  @default(false)
  targetProducts String[] @default([]) @map("target_products")
  priority       Int      @default(50)
  /// 箱自身の田舎主義(Thomas)商品コード。BOMの子Codeと突合してセットの固定箱を判定（2026-06-22）
  thomasCode     String?  @map("thomas_code") @db.VarChar(20)
  note           String?  @db.Text

  setComps     SetComp[]
  inspSessions InspSession[]

  @@index([thomasCode])
  @@map("boxes")
}

/// 6. 運送会社マスタ
model Carrier {
  code     String  @id @db.VarChar(20)
  name     String  @db.VarChar(50)
  short    String? @db.VarChar(20)
  priority Int     @default(99)
  cutoff   String? @db.VarChar(5)
  pickup   String? @db.VarChar(5)
  cool     Boolean @default(false)
  wbType   String? @map("wb_type") @db.VarChar(30)
  contact  String? @db.VarChar(100)
  active   Boolean @default(true)
  note     String? @db.Text

  shippingOrders ShippingOrder[]
  aliases        CarrierAlias[]

  @@map("carriers")
}

/// 6-2. 運送会社 便種名マッピング（2026-06-02 追加）
///   基幹（Thomas）CSV の「配送便種」文字列（例『ヤマト運輸』）→ carriers.code への対応表。
///   旧来は mapping.ts のハードコードだったが、現場で編集できるよう DB マスタ化。
model CarrierAlias {
  id          Int      @id @default(autoincrement())
  /// 基幹側の便種名（CSV の値そのまま）。一意。
  aliasName   String   @unique @map("alias_name") @db.VarChar(100)
  /// 対応する運送会社コード（carriers.code）
  carrierCode String   @map("carrier_code") @db.VarChar(20)
  active      Boolean  @default(true)
  note        String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  carrier Carrier @relation(fields: [carrierCode], references: [code])

  @@index([carrierCode])
  @@map("carrier_aliases")
}

/// 6-3. のし確認 除外マスタ（2026-06-02 追加）
///   検品時、伝票の noshiName / noshiPerson が matchText と完全一致したら
///   「のし☑ 確認」をスルーする（のし対象外として扱う）。
model NoshiExclusion {
  id        Int      @id @default(autoincrement())
  /// 除外対象テキスト（熨斗名称 or 熨斗氏名 と完全一致で判定）。一意。
  matchText String   @unique @map("match_text") @db.VarChar(100)
  active    Boolean  @default(true)
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("noshi_exclusions")
}

/// 6-4. QR印刷 強制マスタ（2026-06-02 追加）
///   取込時、QR印刷フラグが OFF でも noshiName / noshiPerson が matchText と
///   完全一致したら QR印刷フラグを ON にして取り込む（例『特殊包装』）。
model QrForceKeyword {
  id        Int      @id @default(autoincrement())
  /// QR を強制 ON にするテキスト（熨斗名称 or 熨斗氏名 と完全一致で判定）。一意。
  matchText String   @unique @map("match_text") @db.VarChar(100)
  active    Boolean  @default(true)
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("qr_force_keywords")
}

/// 6-5. 本部連絡 サブ選択肢マスタ（②・2026-06-21）
///   タブレット／ハンディの本部連絡モーダルで、分類（のし／商品／伝票／WEB）ごとに
///   表示するサブ選択肢ボタン。タップするとラベル文言が補足テキストへ挿入される。
///   本部へは現仕様通りテキストで送信。マスタ画面から自由に追加・編集できる。
model ContactSubOption {
  id        Int      @id @default(autoincrement())
  /// 連絡分類コード（noshi / product / input(=伝票) / web）。本部連絡モーダルの分類と一致。
  category  String   @db.VarChar(20)
  /// ボタン文言（例: 再印刷）。補足テキストへ挿入される。
  label     String   @db.VarChar(100)
  /// 表示順（小さいほど先頭）
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([category, label])
  @@index([category, active, sortOrder])
  @@map("contact_sub_options")
}

/// 6-6. アプリ設定（key-value）。梱包時間の全体設定など（2026-06-22）。
///   pack.noshi_add_sec / pack.airpack_add_sec（秒）, pack.airpack_keyword（熨斗名称内の判定語）
model AppSetting {
  key       String   @id @db.VarChar(50)
  value     String   @db.VarChar(200)
  valueType String   @default("string") @map("value_type") @db.VarChar(10)
  label     String?  @db.VarChar(100)
  note      String?  @db.Text
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy String?  @map("updated_by") @db.VarChar(10)

  @@map("app_settings")
}

/// 7. 担当者マスタ
model Staff {
  code                String    @id @db.VarChar(10)
  empCode             String    @unique @map("emp_code") @db.VarChar(20)
  name                String    @db.VarChar(30)
  kana                String?   @db.VarChar(40)
  /// ロール: admin / manager / staff / parttime（Sprint Y-5 でアルバイト追加）
  role                String    @default("staff") @db.VarChar(20)
  /// 部署（Sprint Y-5）。例: 製造 / 出荷 / 配送 / 仕分 / 管理 / その他
  department          String?   @db.VarChar(30)
  employmentTypeCode  String?   @map("employment_type_code") @db.VarChar(20)
  groupId             String?   @map("group_id") @db.VarChar(10)
  defaultShiftPattern String?   @map("default_shift_pattern") @db.VarChar(10)
  tel                 String?   @db.VarChar(20)
  joined              DateTime? @db.Date
  assignable          Boolean   @default(true)
  active              Boolean   @default(true)
  /// スキル係数（1.000 = 標準。Phase 6-9 で実績ログから自動更新）
  skillCoefficient    Decimal   @default(1.000) @map("skill_coefficient") @db.Decimal(4, 3)
  /// スキル係数 最終更新日時（Phase 6-9 cron 用）
  skillUpdatedAt      DateTime? @map("skill_updated_at") @db.Timestamptz
  note                String?   @db.Text

  employmentType    EmploymentType?    @relation(fields: [employmentTypeCode], references: [code])
  group             InspectionGroup?   @relation(fields: [groupId], references: [id])
  defaultPattern    ShiftPattern?      @relation(fields: [defaultShiftPattern], references: [code])
  shifts            Shift[]
  inspSessions      InspSession[]
  memberAssignments MemberAssignment[]
  user              User?
  thomasImports     ThomasImport[]
  printLogs         PrintLog[]
  orderAuditLogs    OrderAuditLog[]

  @@index([empCode])
  @@map("staff")
}

/// 8. 端末マスタ
model Device {
  code     String  @id @db.VarChar(20)
  name     String  @db.VarChar(50)
  type     String  @db.VarChar(20)
  model    String? @db.VarChar(50)
  location String? @db.VarChar(50)
  active   Boolean @default(true)

  // Sprint Y-9: 重複ログイン防止用ロック
  //   ログインで占有 → ログアウト/タイムアウトで解放。
  //   activeStaffCode が非 null の間、他の社員はログイン不可。
  activeStaffCode String?   @map("active_staff_code") @db.VarChar(10)
  activeSince     DateTime? @map("active_since") @db.Timestamptz
  lastSeen        DateTime? @map("last_seen") @db.Timestamptz

  printerMap   DevicePrinterMap?
  inspSessions InspSession[]
  printLogs    PrintLog[]

  @@map("devices")
}

/// 9-A. 部署マスタ（Sprint Y-7）
model Department {
  code      String   @id @db.VarChar(20)
  name      String   @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("departments")
}

/// 9. 検品グループマスタ
model InspectionGroup {
  id        String   @id @db.VarChar(10)
  name      String   @db.VarChar(20)
  tables    String[] @default([])
  category  String   @db.VarChar(20)
  needStaff Int      @default(1) @map("need_staff")
  /// Sprint Y-10: ダッシュボード「テーブルグループ別 進捗」カードの表示順
  /// 小さい順に左上から並ぶ。同値の場合は id の辞書順。
  sortOrder Int      @default(100) @map("sort_order")
  note      String?  @db.Text

  staff             Staff[]
  memberAssignments MemberAssignment[]

  @@map("inspection_groups")
}

/// 10. 標準梱包時間マスタ
model StdTime {
  code      String   @id @db.VarChar(20)
  /// グループは可変ラベル（2026-06-30）。inspection_groups への FK は外し、任意の文字列タグとする。
  ///   標準時間の基軸は tableId（伝票のテーブル文字で完了予測フォールバックを引く）。
  groupId   String?  @map("group_id") @db.VarChar(10)
  tableId   String   @map("table_id") @db.VarChar(5)
  stdMin    Decimal  @default(2.00) @map("std_min") @db.Decimal(5, 2)
  source    String   @default("manual") @db.VarChar(10)
  updatedAt DateTime @map("updated_at") @db.Date
  note      String?  @db.Text

  @@map("std_times")
}

/// 11. シフトパターンマスタ
model ShiftPattern {
  code      String  @id @db.VarChar(10)
  name      String  @db.VarChar(50)
  startTime String? @map("start_time") @db.VarChar(5)
  endTime   String? @map("end_time") @db.VarChar(5)
  breakMin  Int     @default(0) @map("break_min")
  isOff     Boolean @default(false) @map("is_off")
  sortOrder Int     @default(0) @map("sort_order")
  active    Boolean @default(true)

  defaultStaff Staff[]
  shifts       Shift[]

  @@map("shift_patterns")
}

/// 12. 雇用区分マスタ
model EmploymentType {
  code       String  @id @db.VarChar(20)
  name       String  @db.VarChar(50)
  dailyHours Decimal @default(8.00) @map("daily_hours") @db.Decimal(4, 2)
  sortOrder  Int     @default(0) @map("sort_order")
  active     Boolean @default(true)

  staff Staff[]

  @@map("employment_types")
}

/// 13. シフトマスタ（日次）
model Shift {
  id          Int       @id @default(autoincrement())
  date        DateTime  @db.Date
  staffCode   String    @map("staff_code") @db.VarChar(10)
  patternCode String    @map("pattern_code") @db.VarChar(10)
  startTime   String?   @map("start_time") @db.VarChar(5)
  endTime     String?   @map("end_time") @db.VarChar(5)
  source      String    @default("manual") @db.VarChar(10)
  importedAt  DateTime? @map("imported_at") @db.Timestamptz
  note        String?   @db.Text

  staff   Staff        @relation(fields: [staffCode], references: [code])
  pattern ShiftPattern @relation(fields: [patternCode], references: [code])

  @@unique([date, staffCode])
  @@index([date])
  @@map("shifts")
}

/// 14. プリンターマスタ
model Printer {
  code      String  @id @db.VarChar(20)
  name      String  @db.VarChar(50)
  ipAddress String  @unique @map("ip_address") @db.VarChar(15)
  port      Int     @default(9100)
  model     String  @default("SCeaTa CT4-LX") @db.VarChar(50)
  location  String? @db.VarChar(50)
  labelSize String  @default("30x40") @map("label_size") @db.VarChar(20)
  active    Boolean @default(true)
  note      String? @db.Text

  deviceMap DevicePrinterMap[]
  printLogs PrintLog[]

  @@map("printers")
}

/// 15. 端末×既定プリンター
model DevicePrinterMap {
  id          Int      @id @default(autoincrement())
  deviceCode  String   @unique @map("device_code") @db.VarChar(20)
  printerCode String   @map("printer_code") @db.VarChar(20)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy   String?  @map("updated_by") @db.VarChar(10)

  device  Device  @relation(fields: [deviceCode], references: [code], onDelete: Cascade)
  printer Printer @relation(fields: [printerCode], references: [code])

  @@map("device_printer_map")
}

/// 16. 連絡事項
model Notice {
  id         Int      @id @default(autoincrement())
  date       DateTime @db.Date
  /// 'announce' = PC→現場 発信、'inbox' = 現場→PC 着信（A-06）
  kind       String   @default("announce") @db.VarChar(10)
  title      String   @db.VarChar(100)
  body       String?  @db.Text
  /// 'all' | 'tablet' | 'handy' | 'group' | 'staff' | 'table'
  targetType String   @default("all") @map("target_type") @db.VarChar(10)
  /// targetType が group / staff / table のときの対象 ID
  targetId   String?  @map("target_id") @db.VarChar(20)
  /// inbox 分類: 'noshi' | 'product' | 'input' | 'web' | 'other'
  category   String?  @db.VarChar(10)
  /// announce で「了解」タップを必須にするか
  ackRequired Boolean @default(false) @map("ack_required")
  /// announce: 発信者 / inbox: 着信元の staff_code
  senderCode String?  @map("sender_code") @db.VarChar(10)
  priority   Int      @default(50)
  active     Boolean  @default(true)
  /// inbox の既読タイムスタンプ（簡易版・全体 read 1 回）
  readAt     DateTime? @map("read_at") @db.Timestamptz
  readBy     String?  @map("read_by") @db.VarChar(10)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  acks NoticeAck[]

  @@index([kind, active, date])
  @@index([kind, readAt])
  @@map("notices")
}

/// 9-B. 連絡事項 個別既読（Sprint Y-16）
///   announce 通知は複数の社員が個別に確認するため、
///   Notice.readAt の global フラグだけでは「他者が読んだら自分には出ない」ことになる。
///   このテーブルで (notice_id, staff_code) ごとに既読を管理する。
model NoticeAck {
  noticeId  Int      @map("notice_id")
  staffCode String   @map("staff_code") @db.VarChar(10)
  ackedAt   DateTime @default(now()) @map("acked_at") @db.Timestamptz

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@id([noticeId, staffCode])
  @@index([staffCode])
  @@map("notice_acks")
}

// =====================================================
// トランザクション系（9テーブル）
// =====================================================

/// 17. 出荷指示ヘッダ（論理削除対応）
model ShippingOrder {
  id           String    @id @default(uuid()) @db.Uuid
  pkNo         String    @unique @map("pk_no") @db.VarChar(30)
  importId     Int?      @map("import_id")
  shipDate     DateTime  @map("ship_date") @db.Date
  carrierCode  String    @map("carrier_code") @db.VarChar(20)
  status       String    @default("pending") @db.VarChar(20)
  qrPrintFlag  Boolean   @default(false) @map("qr_print_flag")
  noshiName    String?   @map("noshi_name") @db.VarChar(50)
  /// 熨斗氏名（2026-06-02 追加・基幹CSV「熨斗氏名」）。のし除外/QR強制の照合に使用。
  noshiPerson  String?   @map("noshi_person") @db.VarChar(50)
  destZip      String?   @map("dest_zip") @db.VarChar(8)
  destAddr     String?   @map("dest_addr") @db.VarChar(200)
  destName     String?   @map("dest_name") @db.VarChar(100)
  invoiceNo    String?   @map("invoice_no") @db.VarChar(30)
  /// 顧客コード（2026-06-12・基幹CSV「顧客コード」M列）。本部連絡の識別子に使用（B）。
  customerCode String?   @map("customer_code") @db.VarChar(30)
  /// 注文番号（2026-06-12・基幹CSV「注文番号」N列）。本部連絡の主識別子に使用（B）。
  orderNo      String?   @map("order_no") @db.VarChar(30)
  holdReason   String?   @map("hold_reason") @db.Text
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy    String?   @map("deleted_by") @db.VarChar(10)
  deleteReason String?   @map("delete_reason") @db.Text
  /// 未検品照合タブ用（A-12）: 'none' | 'barcode' | 'visual'
  matchStatus  String    @default("none") @map("match_status") @db.VarChar(10)
  matchedAt    DateTime? @map("matched_at") @db.Timestamptz
  matchedBy    String?   @map("matched_by") @db.VarChar(10)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  carrier        Carrier             @relation(fields: [carrierCode], references: [code])
  import         ThomasImport?       @relation(fields: [importId], references: [id])
  items          ShippingOrderItem[]
  inspSession    InspSession?
  printLogs      PrintLog[]
  orderAuditLogs OrderAuditLog[]
  /// Sprint Z-1: 引当行
  allocations    Allocation[]

  @@index([shipDate, status])
  @@index([deletedAt])
  @@index([shipDate, matchStatus])
  @@map("shipping_orders")
}

/// 18. 出荷指示明細
model ShippingOrderItem {
  id          Int     @id @default(autoincrement())
  orderId     String  @map("order_id") @db.Uuid
  productCode String  @map("product_code") @db.VarChar(20)
  productName String  @map("product_name") @db.VarChar(100)
  qty         Int
  scannedQty  Int     @default(0) @map("scanned_qty")
  forceOk     Boolean @default(false) @map("force_ok")
  forceReason String? @map("force_reason") @db.Text
  /// 強制OK 理由コード: R01 / R02 / R03 / R04 / R99（A-05）
  forceReasonCode     String?   @map("force_reason_code") @db.VarChar(5)
  /// 強制OK 承認状態: null=未発生 or 未承認 / 'approved' / 'rejected'
  forceApprovalStatus String?   @map("force_approval_status") @db.VarChar(10)
  forceApprovedBy     String?   @map("force_approved_by") @db.VarChar(10)
  forceApprovedAt     DateTime? @map("force_approved_at") @db.Timestamptz
  forceRejectReason   String?   @map("force_reject_reason") @db.Text
  sortOrder           Int       @default(0) @map("sort_order")

  order   ShippingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productCode], references: [code])

  @@unique([orderId, productCode])
  @@index([forceOk, forceApprovalStatus])
  @@map("shipping_order_items")
}

/// 19. 検品セッション
model InspSession {
  id           String    @id @default(uuid()) @db.Uuid
  orderId      String    @unique @map("order_id") @db.Uuid
  staffCode    String    @map("staff_code") @db.VarChar(10)
  deviceCode   String?   @map("device_code") @db.VarChar(20)
  startedAt    DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt  DateTime? @map("completed_at") @db.Timestamptz
  boxCode      String?   @map("box_code") @db.VarChar(30)
  forceOkCount Int       @default(0) @map("force_ok_count")
  durationSec  Int?      @map("duration_sec")

  order  ShippingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  staff  Staff         @relation(fields: [staffCode], references: [code])
  device Device?       @relation(fields: [deviceCode], references: [code])
  box    Box?          @relation(fields: [boxCode], references: [code])
  logs   InspLog[]

  @@index([completedAt])
  @@index([completedAt, staffCode])
  @@map("insp_sessions")
}

/// 20. 検品操作ログ
model InspLog {
  id        Int      @id @default(autoincrement())
  sessionId String   @map("session_id") @db.Uuid
  type      String   @db.VarChar(20)
  itemCode  String?  @map("item_code") @db.VarChar(20)
  qty       Int?
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  session InspSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([type, createdAt])
  @@map("insp_logs")
}

/// 21. 基幹取込履歴
model ThomasImport {
  id            Int      @id @default(autoincrement())
  filename      String   @db.VarChar(200)
  fileType      String   @map("file_type") @db.VarChar(20)
  importedAt    DateTime @default(now()) @map("imported_at") @db.Timestamptz
  totalRows     Int      @default(0) @map("total_rows")
  successCount  Int      @default(0) @map("success_count")
  errorCount    Int      @default(0) @map("error_count")
  janErrorCount Int      @default(0) @map("jan_error_count")
  unmapCount    Int      @default(0) @map("unmap_count")
  importedBy    String?  @map("imported_by") @db.VarChar(10)
  note          String?  @db.Text

  importer       Staff?          @relation(fields: [importedBy], references: [code])
  shippingOrders ShippingOrder[]

  @@index([importedAt])
  @@map("thomas_imports")
}

/// 22. アラート管理
model Alert {
  id         Int       @id @default(autoincrement())
  type       String    @db.VarChar(30)
  severity   String    @default("warn") @db.VarChar(10)
  title      String    @db.VarChar(100)
  body       String?   @db.Text
  refCode    String?   @map("ref_code") @db.VarChar(50)
  resolved   Boolean   @default(false)
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz
  resolvedBy String?   @map("resolved_by") @db.VarChar(10)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("alerts")
}

/// 23. メンバー割当（Gantt）
model MemberAssignment {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  staffCode String   @map("staff_code") @db.VarChar(10)
  groupId   String   @map("group_id") @db.VarChar(10)
  startTime String   @map("start_time") @db.VarChar(5)
  endTime   String   @map("end_time") @db.VarChar(5)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.VarChar(10)

  staff Staff           @relation(fields: [staffCode], references: [code])
  group InspectionGroup @relation(fields: [groupId], references: [id])

  @@index([date, staffCode])
  @@index([date, groupId])
  @@map("member_assignments")
}

/// 24. QR印刷履歴
model PrintLog {
  id          Int      @id @default(autoincrement())
  orderId     String   @map("order_id") @db.Uuid
  pkNo        String   @map("pk_no") @db.VarChar(30)
  invoiceNo   String?  @map("invoice_no") @db.VarChar(30)
  printerCode String   @map("printer_code") @db.VarChar(20)
  deviceCode  String?  @map("device_code") @db.VarChar(20)
  staffCode   String?  @map("staff_code") @db.VarChar(10)
  printedAt   DateTime @default(now()) @map("printed_at") @db.Timestamptz
  isReprint   Boolean  @default(false) @map("is_reprint")
  status      String   @default("success") @db.VarChar(10)
  errorMsg    String?  @map("error_msg") @db.Text

  order   ShippingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  printer Printer       @relation(fields: [printerCode], references: [code])
  device  Device?       @relation(fields: [deviceCode], references: [code])
  staff   Staff?        @relation(fields: [staffCode], references: [code])

  @@map("print_logs")
}

/// 25. 伝票監査ログ（削除/復活/編集）
model OrderAuditLog {
  id      Int      @id @default(autoincrement())
  orderId String   @map("order_id") @db.Uuid
  pkNo    String   @map("pk_no") @db.VarChar(30)
  action  String   @db.VarChar(20)
  actedBy String   @map("acted_by") @db.VarChar(10)
  actedAt DateTime @default(now()) @map("acted_at") @db.Timestamptz
  reason  String?  @db.Text
  diff    Json?

  order ShippingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  staff Staff         @relation(fields: [actedBy], references: [code])

  @@index([orderId])
  @@index([actedAt])
  @@map("order_audit_logs")
}

// =====================================================
// システム系（2テーブル）
// =====================================================

/// 26. 認証ユーザー（管理PC用）
model User {
  id           String    @id @default(uuid()) @db.Uuid
  staffCode    String?   @unique @map("staff_code") @db.VarChar(10)
  email        String    @unique @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(200)
  role         String    @default("staff") @db.VarChar(20)
  active       Boolean   @default(true)
  lastLogin    DateTime? @map("last_login") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  staff    Staff?    @relation(fields: [staffCode], references: [code])
  sessions Session[]

  @@map("users")
}

/// 27. NextAuth セッション
model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token") @db.VarChar(255)
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

/// 29. 顧客属性補助マスタ（Sprint Y-13 / 作業補助タブ）
///   個人/企業/置き配/誤配多発 等、注意が必要な顧客の補助情報。
///   検品時のアラート・置き配判定・誤配警告などに将来連携。
model CustomerAuxAttr {
  id            Int      @id @default(autoincrement())
  customerName  String   @map("customer_name") @db.VarChar(100)
  customerKana  String?  @map("customer_kana") @db.VarChar(100)
  /// 'corp' = 企業 / 'personal' = 個人 / 'leave_at_door' = 置き配指定 /
  /// 'redelivery_alert' = 誤配・再配達多発 / 'attention' = 要注意 / 'note' = メモのみ
  attrType      String   @default("note") @map("attr_type") @db.VarChar(20)
  note          String?  @db.Text
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy     String?  @map("created_by") @db.VarChar(10)

  @@index([customerName])
  @@index([active, attrType])
  @@map("customer_aux_attrs")
}

/// 28. 権限オーバーライド（Sprint Y-10）
///   permissions-shared.ts の DEFAULT を上書き可能にする DB ストア。
///   admin/manager が /settings 画面から編集できる。
///   レコードが無いキーはコード側の既定値を使う（部分オーバーライド可）。
model PermissionOverride {
  permissionKey String   @id @map("permission_key") @db.VarChar(50)
  allowedRoles  String[] @map("allowed_roles") @db.VarChar(20)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy     String?  @map("updated_by") @db.VarChar(10)

  @@map("permission_overrides")
}
