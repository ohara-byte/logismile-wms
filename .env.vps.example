# =====================================================================
# LogiSmile WMS — Xserver VPS 本番 .env テンプレート
#
#   使い方（VPS 上で）:
#     cd /var/www/logismile
#     cp .env.vps.example .env
#     nano .env            # ← ★ の値を実値に置換（秘密はサーバ上で直接入力）
#     docker compose -f docker-compose.vps.yml up -d --build
#
#   このファイル自体はプレースホルダのみ（Git 追跡可）。
#   実値を入れた .env は .gitignore 済み＝コミットされない。
#   秘密鍵・パスワードはチャット等に貼らない（GW規約）。
# =====================================================================

# ── PostgreSQL（compose 内部ネットのみ。ホスト公開なし）──────────────
POSTGRES_USER=wms_user
POSTGRES_DB=wms_db
# ★ 強いランダムパスワードを生成して設定（例: openssl rand -base64 24）
POSTGRES_PASSWORD=__CHANGE_ME_STRONG__

# ── DB 接続（ホスト名は compose のサービス名 logismile_db）──────────
#   ★ パスワード部は上の POSTGRES_PASSWORD と完全一致させること
DATABASE_URL="postgresql://wms_user:__CHANGE_ME_STRONG__@logismile_db:5432/wms_db"

# ── NextAuth ─────────────────────────────────────────────────────────
#   ★ 本番ランダム値（例: openssl rand -base64 32）。弱い値だと起動拒否。
NEXTAUTH_SECRET=__CHANGE_ME_RANDOM_32B__
#   Caddy が https を終端。アプリは https URL を信頼する
NEXTAUTH_URL="https://logismile.oenosato.net"

# ── 社内 IP 制限（最重要）───────────────────────────────────────────
#   Caddy が X-Forwarded-For に実クライアントIP（事務所NAT外側=固定グローバルIP）を載せ、
#   アプリの clientIpFromHeaders が判定する。未設定だと「全許可」になるので必ず設定。
#   ★ <事務所の固定グローバルIP> を実値に。100.64.0.0/10 は Tailscale 帯（在宅管理者がVPNで入る場合用、不要なら削除）。
INTRANET_CIDR_LIST="__OFFICE_GLOBAL_IP__/32,100.64.0.0/10,127.0.0.1/32"

# ── Thomas CSV / アーカイブ（コンテナ内パス。必要ならボリューム追加）──
THOMAS_IMPORT_DIR="./data/thomas_csv"
ARCHIVE_DIR="./data/archives"

# ── 動作モード ───────────────────────────────────────────────────────
NODE_ENV="production"

# =====================================================================
# プリンタ設定（VPS→Tailscale経由でプリンタへ。IPはマスタで管理＝そのまま）
#   ↓ テスト運用機 .env.production.local の実績値をそのまま転記（機微情報ではない）
# =====================================================================
PRINTER_DRY_RUN="false"
PRINTER_LANG="sbpl"
PRINTER_QR_H="0081"
PRINTER_QR_V="00030"
PRINTER_QR_VERSION="1"
PRINTER_QR_ECC="H"
PRINTER_QR_TARGET_WIDTH="160"
PRINTER_QR_TARGET_HEIGHT="160"
PRINTER_QR_OFFSET_X="8"
PRINTER_QR_OFFSET_Y="0"
PRINTER_QR_MASK="auto"
PRINTER_QR_TEXT_GAP="20"
PRINTER_DENSITY="9"
PRINTER_SPEED="1"
# canvas: 22 byte × 26 byterow = 176 × 208 dot（テキスト切れ対策で 26 に拡張済）
PRINTER_CANVAS_W_BYTES="22"
PRINTER_CANVAS_H_BYTEROW="26"
PRINTER_TXT_BELOW="true"
PRINTER_TXT_SCALE="2"
PRINTER_TXT_SCALE_W="2"
PRINTER_TXT_SCALE_H="3"
PRINTER_TXT_SPACING="2"

# =====================================================================
# 製造システム（CraftSmile）連携 — HMAC-SHA256
#   ★ docs/secrets/factory-hmac-secrets-2026-05-31.md の本番分を VPS 上で直接投入。
#   稼働開始まで legacy のままでOK（連携有効化時に factory_api へ）。
# =====================================================================
FACTORY_INTEGRATION_MODE="legacy"
FACTORY_INBOUND_HMAC_SECRET="__FROM_docs_secrets__"
FACTORY_OUTBOUND_HMAC_SECRET="__FROM_docs_secrets__"
FACTORY_WEBHOOK_SECRET="__SAME_AS_INBOUND__"
FACTORY_BASE_URL=""
FACTORY_API_KEY=""
FACTORY_DRY_RUN="true"
